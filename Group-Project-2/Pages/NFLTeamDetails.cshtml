@page
@model Group_Project_2.Pages.NFLTeamDetailsModel

@{
    ViewData["Title"] = "NFL Team Details";
}

<style>
    body {
        background: #0b1220;
        color: #e5e7eb;
    }

    .team-page {
        padding: 30px 0 50px 0;
    }

    .team-hero {
        background: linear-gradient(135deg, #0f172a, #13233d, #1e293b);
        color: white;
        border-radius: 22px;
        padding: 32px;
        margin-bottom: 28px;
        box-shadow: 0 14px 30px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255,255,255,0.08);
    }

    .team-hero-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 24px;
    }

    .team-left {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .team-logo {
        width: 95px;
        height: 95px;
        object-fit: contain;
        background: rgba(255,255,255,.08);
        border-radius: 18px;
        padding: 10px;
        border: 1px solid rgba(255,255,255,.10);
    }

    .team-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
    }

    .team-subtitle {
        margin-top: 8px;
        color: #cbd5e1;
    }

    .team-tags {
        display: flex;
        gap: 10px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .team-tag {
        background: rgba(255,255,255,.10);
        border: 1px solid rgba(255,255,255,.12);
        padding: 8px 14px;
        border-radius: 999px;
        font-size: .9rem;
    }

    .record-box {
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 18px;
        padding: 20px;
        text-align: center;
        min-width: 200px;
    }

    .record-label {
        font-size: .9rem;
        color: #cbd5e1;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .record-value {
        font-size: 2rem;
        font-weight: 800;
    }

    .content-card {
        background: #111827;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 10px 24px rgba(0,0,0,0.25);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .section-title {
        color: #ffffff;
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 18px;
    }

    .info-grid,
    .stats-grid {
        display: grid;
        gap: 16px;
    }

    .info-grid {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .stats-grid {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .info-box,
    .stat-box {
        background: #1f2937;
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 16px;
        padding: 18px;
    }

    .label-text {
        color: #94a3b8;
        font-size: .8rem;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .value-text {
        color: #ffffff;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .table-search-wrap {
        margin-bottom: 16px;
    }

    .table-search {
        width: 100%;
        max-width: 450px;
        background: #1f2937;
        color: #ffffff;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 12px;
        padding: 12px 14px;
        outline: none;
        font-size: 0.95rem;
    }

        .table-search::placeholder {
            color: #94a3b8;
        }

        .table-search:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.15);
        }

    .players-table-wrapper {
        overflow-x: auto;
    }

    .players-table {
        width: 100%;
        border-collapse: collapse;
    }

        .players-table thead th {
            background: #020617;
            color: #cbd5e1;
            padding: 14px;
            text-align: left;
        }

        .players-table tbody td {
            padding: 14px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .players-table tbody tr:nth-child(even) {
            background: rgba(255,255,255,.03);
        }

        .players-table tbody tr:hover {
            background: rgba(59,130,246,.15);
        }

    .player-name {
        font-weight: 700;
        color: white;
    }

    .empty-message {
        padding: 16px;
        border-radius: 14px;
        background: #1f2937;
    }

    .view-btn {
        background: #2563eb;
        color: white;
        padding: 8px 12px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

        .view-btn:hover {
            background: #1d4ed8;
            color: white;
        }

    @@media (max-width: 768px) {
        .team-title {
            font-size: 1.9rem;
        }

        .record-box {
            width: 100%;
        }
    }
</style>

<div class="container team-page">

    @if (Model.Team == null)
    {
        <h2>Team not found.</h2>
    }
    else
    {
        <div class="team-hero">
            <div class="team-hero-content">
                <div class="team-left">
                    <img class="team-logo"
                         src="~/Images/NFL/@(Model.Team.Name).png"
                         alt="@Model.Team.City @Model.Team.Name Logo"
                         onerror="this.style.display='none';" />

                    <div>
                        <h1 class="team-title">@Model.Team.City @Model.Team.Name</h1>
                        <div class="team-subtitle">NFL Team Profile</div>

                        <div class="team-tags">
                            <span class="team-tag">Conference: @Model.Team.Conference</span>
                            <span class="team-tag">Division: @Model.Team.Division</span>
                            <span class="team-tag">Key: @Model.Team.Key</span>
                        </div>
                    </div>
                </div>

                <div class="record-box">
                    <div class="record-label">Current Record</div>
                    @if (Model.Standing != null)
                    {
                        <div class="record-value">@Model.Standing.Wins-@Model.Standing.Losses-@Model.Standing.Ties</div>
                    }
                    else
                    {
                        <div class="record-value">N/A</div>
                    }
                </div>
            </div>
        </div>

        <div class="content-card">
            <h2 class="section-title">Team Info</h2>

            <div class="info-grid">
                <div class="info-box">
                    <div class="label-text">City</div>
                    <div class="value-text">@Model.Team.City</div>
                </div>

                <div class="info-box">
                    <div class="label-text">Team Name</div>
                    <div class="value-text">@Model.Team.Name</div>
                </div>

                <div class="info-box">
                    <div class="label-text">Conference</div>
                    <div class="value-text">@Model.Team.Conference</div>
                </div>

                <div class="info-box">
                    <div class="label-text">Division</div>
                    <div class="value-text">@Model.Team.Division</div>
                </div>
            </div>
        </div>

        <div class="content-card">
            <h2 class="section-title">Team Stats</h2>

            @if (Model.Standing != null)
            {
                <div class="stats-grid">
                    <div class="stat-box">
                        <div class="label-text">Wins</div>
                        <div class="value-text">@Model.Standing.Wins</div>
                    </div>

                    <div class="stat-box">
                        <div class="label-text">Losses</div>
                        <div class="value-text">@Model.Standing.Losses</div>
                    </div>

                    <div class="stat-box">
                        <div class="label-text">Ties</div>
                        <div class="value-text">@Model.Standing.Ties</div>
                    </div>

                    <div class="stat-box">
                        <div class="label-text">Points For</div>
                        <div class="value-text">@Model.Standing.PointsFor</div>
                    </div>

                    <div class="stat-box">
                        <div class="label-text">Points Against</div>
                        <div class="value-text">@Model.Standing.PointsAgainst</div>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-message">No stats available.</div>
            }
        </div>

        <div class="content-card">
            <h2 class="section-title">Players</h2>

            @if (Model.Players != null && Model.Players.Any())
            {
                <div class="table-search-wrap">
                    <input type="text" id="nflPlayerSearch" class="table-search" placeholder="Search players by name, position, number, height, or weight..." />
                </div>

                <div class="players-table-wrapper">
                    <table class="players-table" id="nflPlayersTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Position</th>
                                <th>Number</th>
                                <th>Height</th>
                                <th>Weight</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var player in Model.Players)
                            {
                                <tr>
                                    <td class="player-name">@player.FirstName @player.LastName</td>
                                    <td>@player.Position</td>
                                    <td>@(player.Number.HasValue? player.Number.ToString() : "N/A")</td>
                                    <td>@(string.IsNullOrWhiteSpace(player.Height) ? "N/A" : player.Height)</td>
                                    <td>@(player.Weight == 0 ? "N/A" : player.Weight)</td>
                                    <td>
                                        <a asp-page="/NFLPlayerDetails"
                                           asp-route-firstName="@player.FirstName"
                                           asp-route-lastName="@player.LastName"
                                           asp-route-position="@player.Position"
                                           asp-route-number="@(player.Number.HasValue? player.Number.ToString() : "N/A")"
                                           asp-route-height="@player.Height"
                                           asp-route-weight="@(player.Weight == 0 ? "N/A" : player.Weight.ToString())"
                                           asp-route-teamKey="@Model.Team.Key"
                                           asp-route-teamName="@Model.Team.Name"
                                           asp-route-teamCity="@Model.Team.City"
                                           class="view-btn">
                                            View Player
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-message">No players found.</div>
            }
        </div>
    }
</div>

<script>
    const nflSearchInput = document.getElementById("nflPlayerSearch");
    const nflTable = document.getElementById("nflPlayersTable");

    if (nflSearchInput && nflTable) {
        nflSearchInput.addEventListener("keyup", function () {
            const filter = nflSearchInput.value.toLowerCase();
            const rows = nflTable.querySelectorAll("tbody tr");

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        });
    }
</script>